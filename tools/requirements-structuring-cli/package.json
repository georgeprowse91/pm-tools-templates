{
  "name": "pm-requirements-structuring",
  "version": "1.1.0",
  "description": "LLM-assisted requirements structuring, consistency validation, and test case generation CLI",
  "main": "src/index.js",
  "bin": {
    "pm-requirements": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "test": "node tests/test-runner.js",
    "test:quick": "node tests/test-runner.js --quick",
    "validate": "npm test && echo 'CLI validation complete'",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "requirements-engineering",
    "use-case-specification",
    "test-generation",
    "consistency-validation",
    "llm",
    "project-management"
  ],
  "author": "PM Tools Templates Team",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "axios": "^1.12.0",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "dotenv": "^16.3.0",
    "fs-extra": "^11.0.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "src/**/*",
    "prompts/**/*",
    "schemas/**/*",
    "templates/**/*",
    "examples/**/*",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mirichard/pm-tools-templates.git",
    "directory": "tools/requirements-structuring-cli"
  }
}
