# Requirements Structuring CLI - Configuration
# Copy this file to .env and configure your environment
#
# ┌──────────────────────────────────────────────────────────────────┐
# │  QUICK START: Set ONE API key below. The provider is detected   │
# │  automatically. Gemini is free — no credit card required.       │
# └──────────────────────────────────────────────────────────────────┘

# ================================
# LLM Provider
# ================================
# Auto-detected from whichever API key you set.
# Force a specific provider: gemini | anthropic | openai
LLM_PROVIDER=

# ================================
# Option 1: Google Gemini (FREE)
# ================================
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ================================
# Option 2: Anthropic Claude
# ================================
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ================================
# Option 3: OpenAI
# ================================
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ================================
# Option 4: Any OpenAI-compatible API
# ================================
# Works with: Ollama, Together, Groq, Azure OpenAI, Mistral, LM Studio, etc.
# Set LLM_API_KEY + LLM_BASE_URL + LLM_MODEL for your provider.
#
# Examples:
#   Ollama (local):  LLM_BASE_URL=http://localhost:11434/v1/chat/completions
#   Together AI:     LLM_BASE_URL=https://api.together.xyz/v1/chat/completions
#   Groq:            LLM_BASE_URL=https://api.groq.com/openai/v1/chat/completions
#   LM Studio:       LLM_BASE_URL=http://localhost:1234/v1/chat/completions
LLM_API_KEY=
LLM_BASE_URL=

# ================================
# Model Selection
# ================================
# Override the default model for your provider.
# Leave blank to use the provider default:
#   gemini    → gemini-2.5-flash
#   anthropic → claude-sonnet-4-20250514
#   openai    → gpt-4
LLM_MODEL=

# ================================
# Generation Settings
# ================================

# Temperature for structuring tasks (lower = more deterministic)
LLM_TEMPERATURE_STRUCTURE=0.2

# Temperature for creative tasks like gap analysis (slightly higher)
LLM_TEMPERATURE_CREATIVE=0.5

# Maximum tokens per LLM response
LLM_MAX_TOKENS=16384

# Request timeout in milliseconds
LLM_TIMEOUT=120000

# ================================
# Output Configuration
# ================================

# Default output directory for generated artifacts
OUTPUT_DIR=./output

# Output format for UCS and test cases (json, markdown, both)
OUTPUT_FORMAT=both

# ================================
# Logging Configuration
# ================================

# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# Save LLM prompts and responses for debugging
SAVE_LLM_TRACES=false
LLM_TRACE_DIR=./traces

# ================================
# Development Configuration
# ================================

NODE_ENV=development
